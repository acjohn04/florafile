// FloraFile — Prisma Schema
// Database: SQLite (file-based, zero infrastructure)
// Note: Prisma v7 — url is configured in prisma.config.ts, not here.

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ─── Auth.js Models ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

/// A plant in the user's collection.
model Plant {
  id             String   @id @default(cuid())
  nickname       String
  commonName     String
  scientificName String
  imageUrl       String?
  room           String
  light          String?
  water          String?
  toxicity       String?
  careLevel      String?
  description    String?
  status         String   @default("healthy") // healthy | sick | needs_water | prune_soon

  // Diagnosis fields — populated by AI when an image is uploaded.
  // Null values mean the plant is healthy (no active diagnosis).
  diagnosisName        String?
  severity             String?  // low | medium | high
  diagnosisDescription String?
  recoverySteps        String?  // JSON array stored as text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tasks          Task[]

  @@map("plants")
}

/// A care task assigned to a plant for a specific day of the week.
model Task {
  id          String   @id @default(cuid())
  plantId     String
  plant       Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  type        String   // water | mist | rotate | prune | fertilize
  label       String
  description String?
  dayOfWeek   Int      // 0=Sun … 6=Sat
  completed   Boolean  @default(false)
  weekStart   DateTime // ISO date of the Monday this task belongs to
  createdAt   DateTime @default(now())

  @@map("tasks")
}
